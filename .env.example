# Copy to .env (local) and set the equivalents in your hosting provider's
# environment variables for production builds (Vite bakes these in at BUILD
# time, not runtime — you must rebuild/redeploy after changing them).

# Main NestJS backend (already correctly wired, see src/lib/api.ts)
# No VITE_ var needed for this one — it's hardcoded in src/lib/api.ts as
# https://gmbtebac.onrender.com. Move it to an env var too if you want
# per-environment backends (staging vs prod).

# --- These three default to http://localhost:8000 if unset, which will
#     NEVER work in a deployed environment. If they're not set in your
#     hosting provider's dashboard, Pitch Deck / Proposal Builder / Market
#     Research will silently fail for every real user. ---
VITE_PITCH_DECK_API_URL=https://your-pitch-deck-service.example.com
VITE_PROPOSAL_API_URL=https://your-proposal-service.example.com
VITE_MARKET_RESEARCH_API_URL=https://your-market-research-service.example.com/api/v1

# Hall of Fame dashboard (Next.js app). Local default is http://localhost:3000
VITE_HALL_OF_FAME_URL=http://localhost:3000
